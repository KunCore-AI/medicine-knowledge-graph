# Neo4j 数据库配置
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Flask 服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5001

# 自定义词典路径
CUSTOM_DICT_PATH=custom_dict.txt
